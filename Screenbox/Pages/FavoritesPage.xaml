<Page
    x:Class="Screenbox.Pages.FavoritesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:behaviors="using:Screenbox.Behaviors"
    xmlns:commands="using:Screenbox.Commands"
    xmlns:ctAnimations="using:CommunityToolkit.WinUI.Animations"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:interactivity="using:Microsoft.Xaml.Interactivity"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
    xmlns:strings="using:Screenbox.Strings"
    xmlns:triggers="using:CommunityToolkit.WinUI"
    xmlns:ui="using:CommunityToolkit.WinUI"
    mc:Ignorable="d">

    <Page.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Controls/Templates/GridViewItemTemplates.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <MenuFlyout x:Key="ItemFlyout">
                <MenuFlyoutItem
                    Command="{x:Bind ViewModel.PlayCommand}"
                    CommandParameter="{Binding}"
                    Icon="{ui:FontIcon FontFamily={StaticResource ScreenboxSymbolThemeFontFamily},
                                       Glyph={StaticResource PlayGlyph}}"
                    Text="{strings:Resources Key=Play}" />
                <MenuFlyoutItem
                    Command="{x:Bind Common.PlayNextCommand}"
                    CommandParameter="{Binding}"
                    Icon="{ui:FontIcon FontFamily={StaticResource ScreenboxSymbolThemeFontFamily},
                                       Glyph={StaticResource PlayAddGlyph}}"
                    Text="{strings:Resources Key=PlayNext}" />
                <MenuFlyoutItem
                    Command="{x:Bind Common.AddToQueueCommand}"
                    CommandParameter="{Binding}"
                    Icon="{ui:FontIcon FontFamily={StaticResource ScreenboxSymbolThemeFontFamily},
                                       Glyph={StaticResource PlaylistMusicGlyph}}"
                    Text="{strings:Resources Key=AddToQueue}" />
                <MenuFlyoutSeparator />
                <MenuFlyoutItem
                    Command="{x:Bind ViewModel.RemoveCommand}"
                    CommandParameter="{Binding}"
                    Icon="{ui:FontIcon Glyph=&#xE734;}"
                    Text="{strings:Resources Key=RemoveFromFavorites}" />
                <MenuFlyoutItem
                    Command="{x:Bind Common.EditMediaTagsCommand}"
                    CommandParameter="{Binding}"
                    Icon="{ui:FontIcon Glyph=&#xE70F;}"
                    Text="Edit tag" />
                <MenuFlyoutItem
                    Command="{StaticResource OpenWithCommand}"
                    CommandParameter="{Binding}"
                    Icon="{ui:FontIcon Glyph=&#xE7AC;}"
                    Text="{x:Bind strings:Resources.OpenWith}" />
                <MenuFlyoutItem
                    Command="{StaticResource ShowPropertiesCommand}"
                    CommandParameter="{Binding}"
                    Icon="{ui:FontIcon Glyph=&#xE946;}"
                    Text="{strings:Resources Key=Properties}" />
            </MenuFlyout>
        </ResourceDictionary>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid
            x:Name="HeaderGrid"
            Grid.Row="0"
            MinHeight="{StaticResource PageHeaderMinHeight}"
            Margin="{StaticResource BottomMediumMargin}"
            Padding="{StaticResource ContentPagePadding}">
            <TextBlock
                Style="{StaticResource TitleMediumTextBlockStyle}"
                Text="{strings:Resources Key=Favorites}" />
        </Grid>

        <muxc:ProgressBar
            Grid.Row="1"
            Margin="0,4,0,0"
            VerticalAlignment="Top"
            IsIndeterminate="True"
            Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay}" />

        <GridView
            x:Name="FavoritesGridView"
            Grid.Row="1"
            Margin="{StaticResource TopLargeMargin}"
            Padding="{StaticResource GridViewContentPagePadding}"
            ui:ListViewExtensions.Command="{x:Bind ViewModel.SelectCommand}"
            ui:ScrollViewerExtensions.VerticalScrollBarMargin="{x:Bind Common.ScrollBarMargin, Mode=OneWay}"
            IsItemClickEnabled="True"
            ItemContainerStyle="{StaticResource GridViewItemMediaCardStyle}"
            ItemTemplate="{StaticResource WideMediaGridViewItemTemplate}"
            ItemsSource="{x:Bind ViewModel.Favorites}"
            SelectionMode="None">
            <GridView.Resources>
                <commands:BindableCommand x:Key="MediaListViewItemPlayCommand" Command="{x:Bind ViewModel.PlayCommand}" />
            </GridView.Resources>
            <GridView.Footer>
                <Border Height="{x:Bind Common.FooterBottomPaddingHeight, Mode=OneWay}" />
            </GridView.Footer>
            <interactivity:Interaction.Behaviors>
                <behaviors:AutoFocusBehavior />
                <behaviors:ListViewContextTriggerBehavior Flyout="{StaticResource ItemFlyout}" />
                <behaviors:BringIntoViewWithOffsetBehavior FromBottom="{x:Bind Common.FooterBottomPaddingHeight, Mode=OneWay}" />
                <behaviors:ThumbnailGridViewBehavior />
            </interactivity:Interaction.Behaviors>
        </GridView>

        <Grid
            x:Name="NoFavoritesPanel"
            Grid.Row="1"
            Margin="{x:Bind Common.FooterBottomPaddingMargin, Mode=OneWay}"
            Padding="{StaticResource ContentPagePadding}"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            ColumnSpacing="32"
            Visibility="{x:Bind ViewModel.IsEmpty, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneWay}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.ChildrenTransitions>
                <TransitionCollection>
                    <EntranceThemeTransition />
                </TransitionCollection>
            </Grid.ChildrenTransitions>

            <FontIcon
                x:Name="NoFavoritesPanelIcon"
                Grid.Column="0"
                FontSize="{StaticResource NoContentPanelIconFontSize}"
                Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                Glyph="&#xE734;" />

            <StackPanel
                Grid.Column="1"
                MaxWidth="420"
                VerticalAlignment="Center"
                Orientation="Vertical">
                <TextBlock
                    Margin="0,0,0,4"
                    Style="{StaticResource TitleTextBlockStyle}"
                    Text="{strings:Resources Key=NoFavoritesPanelHeader}" />

                <TextBlock
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Text="{strings:Resources Key=NoFavoritesPanelSubtext}"
                    TextWrapping="Wrap" />
            </StackPanel>
        </Grid>

        <interactivity:Interaction.Behaviors>
            <behaviors:GamepadXYNavigationBehavior />
        </interactivity:Interaction.Behaviors>

        <VisualStateManager.VisualStateGroups>
            <VisualStateGroup x:Name="NavigationViewStates">
                <VisualState x:Name="Expanded" />
                <VisualState x:Name="Compact" />
                <VisualState x:Name="Minimal">
                    <VisualState.StateTriggers>
                        <triggers:IsEqualStateTrigger Value="{x:Bind Common.NavigationViewDisplayMode, Mode=OneWay}" To="{StaticResource MinimalNavigationViewDisplayMode}" />
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="HeaderGrid.Padding" Value="{StaticResource ContentPageMinimalPadding}" />
                        <Setter Target="FavoritesGridView.Padding" Value="{StaticResource GridViewContentPageMinimalPadding}" />
                        <Setter Target="NoFavoritesPanel.Padding" Value="{StaticResource ContentPageMinimalPadding}" />
                        <Setter Target="NoFavoritesPanel.ColumnSpacing" Value="16" />
                        <Setter Target="NoFavoritesPanelIcon.FontSize" Value="{StaticResource NoContentPanelMinimalIconFontSize}" />
                    </VisualState.Setters>
                </VisualState>
            </VisualStateGroup>

            <VisualStateGroup x:Name="SystemEffectsStates">
                <VisualState x:Name="AnimationsEnabled">
                    <VisualState.StateTriggers>
                        <StateTrigger IsActive="{x:Bind Common.AnimationsEnabled, Mode=OneWay}" />
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="FavoritesGridView.(ctAnimations:ItemsReorderAnimation.Duration)" Value="{StaticResource ControlNormalAnimationDuration}" />
                    </VisualState.Setters>
                </VisualState>
            </VisualStateGroup>
        </VisualStateManager.VisualStateGroups>
    </Grid>
</Page>
