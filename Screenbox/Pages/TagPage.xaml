<Page
    x:Class="Screenbox.Pages.TagPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:behaviors="using:Screenbox.Behaviors"
    xmlns:commands="using:Screenbox.Commands"
    xmlns:controls="using:Screenbox.Controls"
    xmlns:ctAnimations="using:CommunityToolkit.WinUI.Animations"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:interactivity="using:Microsoft.Xaml.Interactivity"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
    xmlns:pages="using:Screenbox.Pages"
    xmlns:strings="using:Screenbox.Strings"
    xmlns:triggers="using:CommunityToolkit.WinUI"
    xmlns:ui="using:CommunityToolkit.WinUI"
    xmlns:viewModels="using:Screenbox.Core.ViewModels"
    mc:Ignorable="d">

    <Page.Resources>
        <ResourceDictionary>
            <MenuFlyout x:Key="ItemFlyout">
                <MenuFlyoutItem
                    Command="{x:Bind ViewModel.PlayCommand}"
                    CommandParameter="{Binding}"
                    Icon="{ui:FontIcon FontFamily={StaticResource ScreenboxSymbolThemeFontFamily},
                                       Glyph={StaticResource PlayGlyph}}"
                    Text="{strings:Resources Key=Play}" />
                <MenuFlyoutItem
                    Command="{x:Bind ViewModel.PlayNextCommand}"
                    CommandParameter="{Binding}"
                    Icon="{ui:FontIcon FontFamily={StaticResource ScreenboxSymbolThemeFontFamily},
                                       Glyph={StaticResource PlayAddGlyph}}"
                    Text="{strings:Resources Key=PlayNext}" />
                <MenuFlyoutItem
                    Command="{x:Bind ViewModel.AddToQueueCommand}"
                    CommandParameter="{Binding}"
                    Icon="{ui:FontIcon FontFamily={StaticResource ScreenboxSymbolThemeFontFamily},
                                       Glyph={StaticResource PlaylistMusicGlyph}}"
                    Text="{strings:Resources Key=AddToQueue}" />
                <MenuFlyoutSeparator />
                <MenuFlyoutItem
                    Command="{x:Bind ViewModel.RemoveFromTagCommand}"
                    CommandParameter="{Binding}"
                    Icon="{ui:FontIcon Glyph=&#xE74D;}"
                    Text="Remove from tag" />
                <MenuFlyoutItem
                    Command="{x:Bind Common.EditTagsCommand}"
                    CommandParameter="{Binding}"
                    Icon="{ui:FontIcon Glyph=&#xE70F;}"
                    Text="Edit tag" />
            </MenuFlyout>
        </ResourceDictionary>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid
            x:Name="HeaderGrid"
            Grid.Row="0"
            MinHeight="{StaticResource PageHeaderMinHeight}"
            Margin="{StaticResource BottomMediumMargin}"
            Padding="{StaticResource ContentPagePadding}">
            <TextBlock
                MaxLines="2"
                Style="{StaticResource TitleMediumTextBlockStyle}"
                Text="{x:Bind ViewModel.TitleText, Mode=OneWay}" />
        </Grid>

        <muxc:ProgressBar
            Grid.Row="1"
            Margin="0,4,0,0"
            VerticalAlignment="Top"
            IsIndeterminate="True"
            Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay}" />

        <GridView
            x:Name="TagGridView"
            Grid.Row="1"
            Margin="{StaticResource TopLargeMargin}"
            Padding="{StaticResource GridViewContentPagePadding}"
            ui:ListViewExtensions.Command="{x:Bind ViewModel.ClickCommand}"
            ui:ScrollViewerExtensions.VerticalScrollBarMargin="{x:Bind Common.ScrollBarMargin, Mode=OneWay}"
            IsItemClickEnabled="True"
            ItemContainerStyle="{StaticResource GridViewItemMediaCardStyle}"
            ItemsSource="{x:Bind ViewModel.Items}"
            SelectionMode="None">
            <GridView.Resources>
                <commands:BindableCommand x:Key="MediaListViewItemPlayCommand" Command="{x:Bind ViewModel.PlayCommand}" />
            </GridView.Resources>
            <GridView.ItemTemplate>
                <DataTemplate x:DataType="viewModels:StorageItemViewModel">
                    <controls:CommonGridViewItem
                        Width="{StaticResource WideGridViewItemWidth}"
                        AutomationProperties.Name="{x:Bind pages:FolderViewPage.GetAutomationName(IsFile, DisplayName, DisplayCaption, ItemCount), Mode=OneWay}"
                        CanPlay="{x:Bind IsFile}"
                        Caption="{x:Bind pages:FolderViewPage.GetCaptionText(IsFile, DisplayCaption, ItemCount, Tag), Mode=OneWay}"
                        IsPlaying="{Binding Media.IsPlaying, FallbackValue=False}"
                        IsThumbnailLoading="{x:Bind IsThumbnailLoading, Mode=OneWay}"
                        ThumbnailHeight="{StaticResource WideGridViewItemThumbnailHeight}"
                        ThumbnailSource="{x:Bind ThumbnailSource, Mode=OneWay, FallbackValue={x:Null}}"
                        Title="{x:Bind DisplayName, Mode=OneWay}">
                        <controls:CommonGridViewItem.PlaceholderIconSource>
                            <FontIconSource FontSize="{StaticResource WideGridItemPlaceholderIconFontSize}" Glyph="{x:Bind StorageItem, Converter={StaticResource MediaGlyphConverter}}" />
                        </controls:CommonGridViewItem.PlaceholderIconSource>
                    </controls:CommonGridViewItem>
                </DataTemplate>
            </GridView.ItemTemplate>
            <GridView.Footer>
                <Border Height="{x:Bind Common.FooterBottomPaddingHeight, Mode=OneWay}" />
            </GridView.Footer>
            <interactivity:Interaction.Behaviors>
                <behaviors:AutoFocusBehavior />
                <behaviors:ListViewContextTriggerBehavior Flyout="{StaticResource ItemFlyout}" />
                <behaviors:BringIntoViewWithOffsetBehavior FromBottom="{x:Bind Common.FooterBottomPaddingHeight, Mode=OneWay}" />
                <behaviors:ThumbnailGridViewBehavior />
            </interactivity:Interaction.Behaviors>
        </GridView>

        <Grid
            x:Name="NoTaggedItemsPanel"
            Grid.Row="1"
            Margin="{x:Bind Common.FooterBottomPaddingMargin, Mode=OneWay}"
            Padding="{StaticResource ContentPagePadding}"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            ColumnSpacing="32"
            Visibility="{x:Bind ViewModel.IsEmpty, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneWay}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <FontIcon
                x:Name="NoTaggedItemsPanelIcon"
                Grid.Column="0"
                FontSize="{StaticResource NoContentPanelIconFontSize}"
                Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                Glyph="&#xE8EC;" />

            <StackPanel
                Grid.Column="1"
                MaxWidth="420"
                VerticalAlignment="Center"
                Orientation="Vertical">
                <TextBlock
                    Margin="0,0,0,4"
                    Style="{StaticResource TitleTextBlockStyle}"
                    Text="No tagged items" />

                <TextBlock
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Text="Right-click a video or folder and choose Add tag."
                    TextWrapping="Wrap" />
            </StackPanel>
        </Grid>

        <interactivity:Interaction.Behaviors>
            <behaviors:GamepadXYNavigationBehavior />
        </interactivity:Interaction.Behaviors>

        <VisualStateManager.VisualStateGroups>
            <VisualStateGroup x:Name="NavigationViewStates">
                <VisualState x:Name="Expanded" />
                <VisualState x:Name="Compact" />
                <VisualState x:Name="Minimal">
                    <VisualState.StateTriggers>
                        <triggers:IsEqualStateTrigger Value="{x:Bind Common.NavigationViewDisplayMode, Mode=OneWay}" To="{StaticResource MinimalNavigationViewDisplayMode}" />
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="HeaderGrid.Padding" Value="{StaticResource ContentPageMinimalPadding}" />
                        <Setter Target="TagGridView.Padding" Value="{StaticResource GridViewContentPageMinimalPadding}" />
                        <Setter Target="NoTaggedItemsPanel.Padding" Value="{StaticResource ContentPageMinimalPadding}" />
                        <Setter Target="NoTaggedItemsPanel.ColumnSpacing" Value="16" />
                        <Setter Target="NoTaggedItemsPanelIcon.FontSize" Value="{StaticResource NoContentPanelMinimalIconFontSize}" />
                    </VisualState.Setters>
                </VisualState>
            </VisualStateGroup>

            <VisualStateGroup x:Name="SystemEffectsStates">
                <VisualState x:Name="AnimationsEnabled">
                    <VisualState.StateTriggers>
                        <StateTrigger IsActive="{x:Bind Common.AnimationsEnabled, Mode=OneWay}" />
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="TagGridView.(ctAnimations:ItemsReorderAnimation.Duration)" Value="{StaticResource ControlNormalAnimationDuration}" />
                    </VisualState.Setters>
                </VisualState>
            </VisualStateGroup>
        </VisualStateManager.VisualStateGroups>
    </Grid>
</Page>
