<Page
    x:Class="Screenbox.Pages.AllVideosPage"
    x:Name="PageRoot"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:behaviors="using:Screenbox.Behaviors"
    xmlns:commands="using:Screenbox.Commands"
    xmlns:controls="using:Screenbox.Controls"
    xmlns:ctAnimations="using:CommunityToolkit.WinUI.Animations"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:interactivity="using:Microsoft.Xaml.Interactivity"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
    xmlns:strings="using:Screenbox.Strings"
    xmlns:triggers="using:CommunityToolkit.WinUI"
    xmlns:ui="using:CommunityToolkit.WinUI"
    xmlns:viewModels="using:Screenbox.Core.ViewModels"
    mc:Ignorable="d">

    <Page.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Controls/Templates/GridViewItemTemplates.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <MenuFlyout x:Key="ItemFlyout">
                <interactivity:Interaction.Behaviors>
                    <behaviors:AddToPlaylistFlyoutBehavior TargetSubItemName="AddToPlaylistSubMenu" />
                </interactivity:Interaction.Behaviors>

                <MenuFlyoutItem
                    Command="{x:Bind ViewModel.PlayCommand}"
                    CommandParameter="{Binding}"
                    Icon="{ui:FontIcon FontFamily={StaticResource ScreenboxSymbolThemeFontFamily},
                                       Glyph={StaticResource PlayGlyph}}"
                    Text="{strings:Resources Key=Play}" />
                <MenuFlyoutItem
                    Command="{x:Bind Common.PlayNextCommand}"
                    CommandParameter="{Binding}"
                    Icon="{ui:FontIcon FontFamily={StaticResource ScreenboxSymbolThemeFontFamily},
                                       Glyph={StaticResource PlayAddGlyph}}"
                    Text="{strings:Resources Key=PlayNext}" />
                <MenuFlyoutItem
                    Command="{x:Bind Common.AddToQueueCommand}"
                    CommandParameter="{Binding}"
                    Icon="{ui:FontIcon FontFamily={StaticResource ScreenboxSymbolThemeFontFamily},
                                       Glyph={StaticResource PlaylistMusicGlyph}}"
                    Text="{strings:Resources Key=AddToQueue}" />
                <MenuFlyoutSeparator />
                <MenuFlyoutItem
                    Command="{x:Bind Common.AddToFavoritesCommand}"
                    CommandParameter="{Binding}"
                    Icon="{ui:FontIcon Glyph=&#xE734;}"
                    Text="{strings:Resources Key=AddToFavorites}" />
                <MenuFlyoutItem
                    Command="{x:Bind Common.EditMediaTagsCommand}"
                    CommandParameter="{Binding}"
                    Icon="{ui:FontIcon Glyph=&#xE70F;}"
                    Text="Edit tag" />
                <MenuFlyoutSubItem
                    x:Name="AddToPlaylistSubMenu"
                    Icon="{ui:SymbolIcon Symbol=Add}"
                    Text="{strings:Resources Key=AddToPlaylist}" />
                <MenuFlyoutItem
                    Command="{StaticResource OpenWithCommand}"
                    CommandParameter="{Binding}"
                    Icon="{ui:FontIcon Glyph=&#xE7AC;}"
                    Text="{x:Bind strings:Resources.OpenWith}" />
                <MenuFlyoutItem
                    Command="{StaticResource ShowPropertiesCommand}"
                    CommandParameter="{Binding}"
                    Icon="{ui:FontIcon Glyph=&#xE946;}"
                    Text="{strings:Resources Key=Properties}" />
                <MenuFlyoutSeparator Visibility="{x:Bind Common.IsAdvancedModeEnabled}" />
                <MenuFlyoutItem
                    CommandParameter="{Binding}"
                    Icon="{ui:SymbolIcon Symbol=Setting}"
                    Text="{strings:Resources Key=SetPlaybackOptions}"
                    Visibility="{x:Bind Common.IsAdvancedModeEnabled}">
                    <MenuFlyoutItem.Command>
                        <commands:SetPlaybackOptionsCommand PlayCommand="{x:Bind ViewModel.PlayCommand}" />
                    </MenuFlyoutItem.Command>
                </MenuFlyoutItem>
            </MenuFlyout>
        </ResourceDictionary>
    </Page.Resources>

    <interactivity:Interaction.Behaviors>
        <behaviors:AutoFocusBehavior />
    </interactivity:Interaction.Behaviors>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ScrollViewer
            Grid.Row="0"
            Margin="{StaticResource ContentPagePadding}"
            HorizontalScrollBarVisibility="Auto"
            HorizontalScrollMode="Enabled"
            Padding="0,0,0,12"
            VerticalScrollBarVisibility="Disabled"
            VerticalScrollMode="Disabled"
            ZoomMode="Disabled">
            <Grid ColumnSpacing="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <StackPanel
                Grid.Column="0"
                Width="400"
                Spacing="6">
                <TextBlock
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Style="{StaticResource CaptionTextBlockStyle}"
                    Text="Search" />
                <AutoSuggestBox
                    Width="400"
                    Height="40"
                    PlaceholderText="Search videos"
                    QueryIcon="Find"
                    Text="{x:Bind ViewModel.SearchQuery, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
            </StackPanel>

            <StackPanel
                Grid.Column="1"
                Width="180"
                Spacing="6">
                <TextBlock
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Style="{StaticResource CaptionTextBlockStyle}"
                    Text="Thumbnail size" />
                <ComboBox
                    Width="180"
                    Height="40"
                    ItemsSource="{x:Bind ViewModel.ThumbnailSizeOptions}"
                    SelectedIndex="{x:Bind ViewModel.SelectedThumbnailSizeIndex, Mode=TwoWay}" />
            </StackPanel>

            <StackPanel
                Grid.Column="2"
                Width="190"
                Spacing="6">
                <TextBlock
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Style="{StaticResource CaptionTextBlockStyle}"
                    Text="Sort" />
                <ComboBox
                    Width="190"
                    Height="40"
                    ItemsSource="{x:Bind ViewModel.SortOptions}"
                    SelectedIndex="{x:Bind ViewModel.SelectedSortIndex, Mode=TwoWay}" />
            </StackPanel>

            <StackPanel Grid.Column="3" Spacing="6">
                <TextBlock
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Style="{StaticResource CaptionTextBlockStyle}"
                    Text="Actions" />
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button
                        Width="40"
                        Height="40"
                        Padding="0"
                        Command="{x:Bind ViewModel.RefreshCommand}"
                        ToolTipService.ToolTip="Refresh">
                        <SymbolIcon Symbol="Refresh" />
                    </Button>

                    <ToggleButton
                        x:Name="SelectionModeToggleButton"
                        Height="40"
                        MinWidth="72"
                        Click="SelectionModeToggleButton_OnClick"
                        Content="Select" />

                    <Button
                        x:Name="AddTagsToSelectionButton"
                        Height="40"
                        MinWidth="96"
                        Click="AddTagsToSelectionButton_OnClick"
                        IsEnabled="False"
                        Visibility="Collapsed">
                        <StackPanel Orientation="Horizontal">
                            <FontIcon
                                Margin="{StaticResource IconButtonStandardIconMargin}"
                                Glyph="&#xE8EC;" />
                            <TextBlock Margin="8,0,0,0" Text="Set tag" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </StackPanel>
            </Grid>
        </ScrollViewer>

        <muxc:ProgressBar
            Grid.Row="1"
            VerticalAlignment="Top"
            IsIndeterminate="True"
            Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay}" />
        <GridView
            x:Name="VideosGridView"
            Grid.Row="1"
            Margin="{StaticResource TopLargeMargin}"
            Padding="{StaticResource GridViewContentPagePadding}"
            ui:ListViewExtensions.Command="{x:Bind ViewModel.SelectCommand}"
            IsItemClickEnabled="True"
            ItemContainerStyle="{StaticResource GridViewItemMediaCardStyle}"
            ItemsSource="{x:Bind ViewModel.Videos}"
            SelectionChanged="VideosGridView_OnSelectionChanged"
            SelectionMode="None">
            <GridView.Resources>
                <commands:BindableCommand x:Key="MediaListViewItemPlayCommand" Command="{x:Bind ViewModel.PlayCommand}" />
            </GridView.Resources>
            <GridView.ItemTemplate>
                <DataTemplate x:DataType="viewModels:MediaViewModel">
                    <controls:CommonGridViewItem
                        Title="{x:Bind DisplayName, Mode=OneWay}"
                        Width="{Binding DataContext.ThumbnailWidth, ElementName=PageRoot}"
                        Caption="{x:Bind AllVideosCaption, Mode=OneWay}"
                        IsPlaying="{Binding IsPlaying, FallbackValue=False}"
                        IsThumbnailLoading="{x:Bind IsThumbnailLoading, Mode=OneWay}"
                        ThumbnailHeight="{Binding DataContext.ThumbnailHeight, ElementName=PageRoot}"
                        ThumbnailSource="{x:Bind Thumbnail, Mode=OneWay}">
                        <controls:CommonGridViewItem.PlaceholderIconSource>
                            <FontIconSource FontSize="{StaticResource WideGridItemPlaceholderIconFontSize}" Glyph="{Binding Converter={StaticResource MediaGlyphConverter}}" />
                        </controls:CommonGridViewItem.PlaceholderIconSource>
                    </controls:CommonGridViewItem>
                </DataTemplate>
            </GridView.ItemTemplate>
            <GridView.Footer>
                <Border Height="{x:Bind Common.FooterBottomPaddingHeight, Mode=OneWay}" />
            </GridView.Footer>
            <interactivity:Interaction.Behaviors>
                <behaviors:ListViewContextTriggerBehavior Flyout="{StaticResource ItemFlyout}" />
                <behaviors:BringIntoViewWithOffsetBehavior FromBottom="{x:Bind Common.FooterBottomPaddingHeight, Mode=OneWay}" />
                <behaviors:ThumbnailGridViewBehavior />
            </interactivity:Interaction.Behaviors>
        </GridView>

        <VisualStateManager.VisualStateGroups>
            <VisualStateGroup x:Name="NavigationViewStates">
                <VisualState x:Name="Expanded" />
                <VisualState x:Name="Compact" />
                <VisualState x:Name="Minimal">
                    <VisualState.StateTriggers>
                        <triggers:IsEqualStateTrigger Value="{x:Bind Common.NavigationViewDisplayMode, Mode=OneWay}" To="{StaticResource MinimalNavigationViewDisplayMode}" />
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="VideosGridView.Padding" Value="{StaticResource GridViewContentPageMinimalPadding}" />
                    </VisualState.Setters>
                </VisualState>
            </VisualStateGroup>

            <VisualStateGroup x:Name="SystemEffectsStates">
                <VisualState x:Name="AnimationsEnabled">
                    <VisualState.StateTriggers>
                        <StateTrigger IsActive="{x:Bind Common.AnimationsEnabled, Mode=OneWay}" />
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="VideosGridView.(ctAnimations:ItemsReorderAnimation.Duration)" Value="{StaticResource ControlNormalAnimationDuration}" />
                    </VisualState.Setters>
                </VisualState>
            </VisualStateGroup>
        </VisualStateManager.VisualStateGroups>
    </Grid>
</Page>
