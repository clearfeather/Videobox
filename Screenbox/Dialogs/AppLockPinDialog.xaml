<ContentDialog
    x:Class="Screenbox.Dialogs.AppLockPinDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="{x:Bind DialogTitle}"
    CloseButtonText="{x:Bind CloseText}"
    DefaultButton="Primary"
    PrimaryButtonText="{x:Bind PrimaryText}"
    Style="{StaticResource DefaultContentDialogStyle}"
    mc:Ignorable="d">

    <StackPanel Spacing="8">
        <PasswordBox
            x:Name="PinBox"
            MaxLength="4"
            PasswordChanged="PinBox_OnPasswordChanged"
            PlaceholderText="4-digit PIN" />
        <TextBlock
            x:Name="ErrorText"
            Style="{StaticResource CaptionTextBlockStyle}"
            TextWrapping="Wrap" />
    </StackPanel>
</ContentDialog>
